<!-- HERO SLIDER -->
<section class="hero-section">
  <div class="hero-slide">
    <div class="hero-content">
      <div class="hero-tag">NEW COLLECTION 2024</div>
      <h1 class="hero-title">THREADS THAT<br>CONNECT SOULS</h1>
      <a href="/collections/all" class="hero-btn">SHOP COLLECTION</a>
    </div>
    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" class="hero-img" alt="Soul Fit Hero">
    {% else %}
      <div class="hero-img" style="background: #e8e4de;"></div>
    {% endif %}
  </div>
</section>

<!-- CATEGORIES -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Category of Clothes</h2>
    <div class="categories-grid">
      {% for collection in collections limit: 4 %}
        <a href="{{ collection.url }}" class="category-card">
          <div class="category-img-wrap">
            {% if collection.featured_image %}
              <img src="{{ collection.featured_image | image_url: width: 400 }}" class="category-img" alt="{{ collection.title }}">
            {% else %}
              <div class="category-img" style="background: #eee;"></div>
            {% endif %}
          </div>
          <p class="category-name">{{ collection.title }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FEATURES STRIP -->
<div class="container">
  <div class="features-strip">
    <div class="feature-card">
      <div class="feature-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M5 12l5 5L20 7" /></svg>
      </div>
      <div class="feature-text">
        <div class="feature-title">100% Original</div>
        <div class="feature-sub">Guaranteed authentic</div>
      </div>
    </div>
    <div class="feature-card">
      <div class="feature-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><circle cx="12" cy="12" r="10" /><path d="M12 8v4l3 3" /></svg>
      </div>
      <div class="feature-text">
        <div class="feature-title">Fast Delivery</div>
        <div class="feature-sub">Within 2-4 days</div>
      </div>
    </div>
    <div class="feature-card">
      <div class="feature-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24"><path d="M3 3h18v18H3z" /><path d="M9 9h6v6H9z" /></svg>
      </div>
      <div class="feature-text">
        <div class="feature-title">Easy Returns</div>
        <div class="feature-sub">7 days return policy</div>
      </div>
    </div>
  </div>
</div>

<!-- NEW ARRIVALS -->
<section class="section" style="padding-top: 0;">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">New Arrivals</h2>
      <a href="/collections/all" class="view-all">View All <span>›</span></a>
    </div>
    <div class="products-grid">
      {% for product in collections.all.products limit: 4 %}
        <div class="product-card">
          <div class="product-img-wrap">
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | image_url: width: 600 }}" class="product-img" alt="{{ product.title }}">
            </a>
          </div>
          <div class="product-info">
            <div class="prod-meta">
              <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">
                <div class="prod-name">{{ product.title }}</div>
                <div class="prod-price">{{ product.price | money }}</div>
              </a>
            </div>
            {% form 'product', product, class: 'add-to-cart-form' %}
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="prod-cart-btn" aria-label="Add to cart">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </button>
            {% endform %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ASSURANCES -->
<section class="section">
  <div class="container">
    <div class="assurances-wrap">
      <div class="assurance-item">
        <div class="assurance-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="24" height="24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
        </div>
        <div>
          <h4 class="assurance-title">Premium Quality</h4>
          <p class="assurance-desc">Every piece is crafted with extreme attention.</p>
        </div>
      </div>
      <div class="assurance-item">
        <div class="assurance-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="24" height="24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
        </div>
        <div>
          <h4 class="assurance-title">Secure Payments</h4>
          <p class="assurance-desc">100% secure payment gateways.</p>
        </div>
      </div>
      <div class="assurance-item">
        <div class="assurance-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="24" height="24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <div>
          <h4 class="assurance-title">24x7 Available</h4>
          <p class="assurance-desc">Dedicated support team around the clock.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homepage",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ]
}
{% endschema %}
