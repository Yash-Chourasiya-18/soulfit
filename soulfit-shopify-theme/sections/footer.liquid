<footer class="footer-v2">
  <div class="footer-v2-inner">
    <!-- TOP: LOGO & TAGLINE -->
    <div class="footer-top">
      <div class="logo-text" style="color: var(--black); margin-bottom: 20px;">
        <span class="logo-soul" style="font-size: 32px;">SOUL</span><span class="logo-divider" style="font-size: 32px;">|</span><span class="logo-fit" style="font-size: 32px;">FIT</span>
      </div>
      <p class="footer-v2-desc">
        Soul Fit is more than fashion — it's a feeling.<br />
        We create threads that connect souls and celebrate individuality.
      </p>
    </div>

    <!-- MIDDLE: 4 COLUMNS -->
    <div class="footer-v2-cols">
      <div class="footer-v2-col">
        <h4><span class="gold-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></span> SHOP</h4>
        {% for link in linklists.main-menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </div>
      <div class="footer-v2-col">
        <h4><span class="gold-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="4"></circle></svg></span> HELP</h4>
        <a href="/pages/track-order">Track Order</a>
        <a href="/pages/shipping-policy">Shipping Policy</a>
        <a href="/pages/returns">Returns & Refunds</a>
        <a href="/pages/faq">FAQ</a>
      </div>
      <div class="footer-v2-col">
        <h4><span class="gold-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg></span> COMPANY</h4>
        <a href="/pages/about-us">About Us</a>
        <a href="/pages/careers">Careers</a>
        <a href="/blogs/news">Blog</a>
      </div>
      <div class="footer-v2-col">
        <h4><span class="gold-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg></span> LEGAL</h4>
        <a href="/pages/privacy-policy">Privacy Policy</a>
        <a href="/pages/terms-conditions">Terms & Conditions</a>
      </div>
    </div>

    <!-- BOTTOM: NEWSLETTER, SOCIAL, FEATURES -->
    <div class="footer-v2-bottom">
      <div class="footer-v2-newsletter">
        <h4>STAY CONNECTED</h4>
        <p>Join our community and get 10% off on your first order.</p>
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="Enter your email" required>
          <button type="submit">SUBSCRIBE</button>
        {% endform %}
      </div>

      <div class="footer-v2-social">
        <h4>FOLLOW US</h4>
        <div class="social-icons">
          <a href="#" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="#" aria-label="WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </div>
      </div>

      <div class="footer-v2-features">
        <div class="feat-item">
          <span class="feat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg></span>
          <div>
            <h5>FREE SHIPPING</h5>
            <p>On orders above ₹999</p>
          </div>
        </div>
        <div class="feat-item">
          <span class="feat-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg></span>
          <div>
            <h5>EASY RETURNS</h5>
            <p>7 days return policy</p>
          </div>
        </div>
      </div>
    </div>

    <!-- VERY BOTTOM: COPYRIGHT -->
    <div class="footer-v2-copyright">
      <p>&copy; {{ 'now' | date: "%Y" }} Soul Fit. All rights reserved.</p>
      <p>Made with 🤍 for souls like yours.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
